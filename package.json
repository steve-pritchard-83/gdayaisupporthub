{
  "name": "gdayai-support-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://steve-pritchard-83.github.io/gdayaisupporthub",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:analyze": "npm run build && npx vite-bundle-analyzer dist",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "npm run lint -- --fix",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "git add docs && git commit -m \"Deploy to GitHub Pages\" && git push",
    "clean": "Remove-Item -Path docs,node_modules\\.cache -Recurse -Force -ErrorAction SilentlyContinue",
    "reset": "npm run clean && npm install",
    "check": "npm run type-check && npm run lint"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.3.0",
    "typescript": "^5.0.0",
    "uuid": "^9.0.1",
    "vite": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript-eslint": "^8.34.1"
  }
}
